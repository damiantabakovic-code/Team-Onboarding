      <div style={{ background: c.bg, padding: "1.5rem 1.5rem 1rem", borderBottom: `2px solid ${c.border}` }}>
        <div style={{ maxWidth: "680px", margin: "0 auto" }}>
          <div style={{ fontSize: "0.68rem", letterSpacing: "0.2em", color: c.accent, textTransform: "uppercase", fontFamily: "sans-serif", marginBottom: "0.3rem" }}>
            Enagic Business Builder
          </div>
          <h1 style={{ color: c.deep, fontSize: "1.5rem", margin: "0 0 0.2rem", fontWeight: "700" }}>Your Grand Slam Offer</h1>
          <p style={{ color: c.mid, fontFamily: "sans-serif", fontSize: "0.8rem", margin: "0 0 0.75rem", lineHeight: "1.5" }}>
            Answer honestly. There are no wrong answers. This is the foundation of your entire business and content strategy.
          </p>
          <ProgressBar current={currentSection + 1} total={totalSections} />
          <div style={{ display: "flex", justifyContent: "space-between", fontFamily: "sans-serif", fontSize: "0.72rem", color: c.muted }}>
            <span>Section {currentSection + 1} of {totalSections}</span>
            <span>{sections.filter((s, i) => i <= currentSection && sectionComplete(s)).length} complete</span>
          </div>
        </div>
      </div>

      {/* Section Nav Pills */}
      <div style={{ background: c.bg, borderBottom: `1px solid ${c.border}`, overflowX: "auto", display: "flex", gap: "0.4rem", padding: "0.6rem 1.5rem" }}>
        {sections.map((s, i) => (
          <button key={i} onClick={() => setCurrentSection(i)}
            style={{ padding: "0.4rem 0.85rem", borderRadius: "20px", border: `1.5px solid ${i === currentSection ? c.accent : sectionComplete(s) ? c.accent : c.border}`, background: i === currentSection ? c.accent : sectionComplete(s) ? c.accentLight : "#fff",
            color: i === currentSection ? "#fff" : sectionComplete(s) ? c.accent : c.mid, fontFamily: "sans-serif", fontSize: "0.72rem", fontWeight: "600", cursor: "pointer", whiteSpace: "nowrap", transition: "all 0.2s" }}>
            {sectionComplete(s) && i !== currentSection ? "✓ " : ""}{s.emoji} {s.title}
          </button>
        ))}
      </div>

      {/* Section Content */}
      <div style={{ padding: "1.5rem", maxWidth: "680px", margin: "0 auto" }}>
        <div style={{ marginBottom: "1.5rem" }}>
          <h2 style={{ fontSize: "1.2rem", margin: "0 0 0.3rem", color: c.deep }}>{section.emoji} {section.title}</h2>
          <p style={{ fontFamily: "sans-serif", fontSize: "0.84rem", color: c.mid, margin: 0, lineHeight: "1.6" }}>{section.subtitle}</p>
        </div>

        {section.questions.map(q => (
          <Question key={q.id} q={q} value={answers[q.id]} onChange={(val) => setAnswer(q.id, val)} />
        ))}

        <div style={{ display: "flex", gap: "0.75rem", marginTop: "1rem" }}>
          {currentSection > 0 && (
            <button onClick={() => setCurrentSection(prev => prev - 1)}
              style={{ flex: 1, padding: "0.9rem", borderRadius: "10px", border: `1.5px solid ${c.border}`, background: "#fff", color: c.mid, fontFamily: "sans-serif", fontSize: "0.88rem", fontWeight: "600", cursor: "pointer" }}>
              ← Back
            </button>
          )}
          {currentSection < totalSections - 1 ? (
            <button onClick={() => setCurrentSection(prev => prev + 1)}
              style={{ flex: 2, padding: "0.9rem", borderRadius: "10px", border: "none", background: sectionComplete(section) ? c.accent : c.border, color: "#fff", fontFamily: "sans-serif", fontSize: "0.88rem", fontWeight: "700", cursor: sectionComplete(section) ? "pointer" : "default", transition: "background 0.2s" }}>
              Next section →
            </button>
          ) : (
            <button onClick={() => allComplete && setShowSummary(true)}
              style={{ flex: 2, padding: "0.9rem", borderRadius: "10px", border: "none", background: allComplete ? c.accent : c.border, color: "#fff", fontFamily: "sans-serif", fontSize: "0.88rem", fontWeight: "700", cursor: allComplete ? "pointer" : "default", transition: "background 0.2s" }}>
              {allComplete ? "Generate my offer summary →" : "Complete all sections first"}
            </button>
          )}
        </div>

        {!sectionComplete(section) && (
          <p style={{ fontFamily: "sans-serif", fontSize: "0.75rem", color: c.muted, textAlign: "center", marginTop: "0.75rem" }}>
            Answer all questions in this section to continue
          </p>
        )}
      </div>
    </div>
  );
}
