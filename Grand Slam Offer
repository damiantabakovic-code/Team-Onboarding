function ProgressBar({ current, total }) {
  return (
    <div style={{ background: c.border, borderRadius: "99px", height: "6px", margin: "1rem 0 0.5rem" }}>
      <div style={{ background: c.accent, borderRadius: "99px", height: "6px", width: `${(current / total) * 100}%`, transition: "width 0.4s ease" }} />
    </div>
  );
}

function CheckboxGroup({ options, value = [], onChange, tip }) {
  const toggle = (opt) => {
    const next = value.includes(opt) ? value.filter(v => v !== opt) : [...value, opt];
    onChange(next);
  };
  return (
    <div>
      <div style={{ display: "flex", flexDirection: "column", gap: "0.5rem" }}>
        {options.map(opt => (
          <button key={opt} onClick={() => toggle(opt)}
            style={{ display: "flex", alignItems: "center", gap: "0.75rem", padding: "0.65rem 0.85rem", borderRadius: "8px", border: `1.5px solid ${value.includes(opt) ? c.accent : c.border}`, background: value.includes(opt) ? c.accentLight : "#fff", cursor: "pointer", textAlign: "left", transition: "all 0.15s" }}>
            <div style={{ width: "18px", height: "18px", borderRadius: "4px", border: `2px solid ${value.includes(opt) ? c.accent : c.border}`, background: value.includes(opt) ? c.accent : "#fff", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
              {value.includes(opt) && <span style={{ color: "#fff", fontSize: "11px", fontWeight: "700" }}>✓</span>}
            </div>
            <span style={{ fontFamily: "sans-serif", fontSize: "0.85rem", color: value.includes(opt) ? c.accent : c.deep }}>{opt}</span>
          </button>
        ))}
      </div>
      {tip && <p style={{ fontFamily: "sans-serif", fontSize: "0.75rem", color: c.muted, marginTop: "0.5rem", fontStyle: "italic" }}>💡 {tip}</p>}
    </div>
  );
}

function Question({ q, value, onChange }) {
  return (
    <div style={{ marginBottom: "1.75rem" }}>
      <label style={{ display: "block", fontFamily: "sans-serif", fontWeight: "600", fontSize: "0.9rem", color: c.deep, marginBottom: "0.4rem", lineHeight: "1.4" }}>{q.label}</label>
      {q.tip && <p style={{ fontFamily: "sans-serif", fontSize: "0.75rem", color: c.muted, marginBottom: "0.5rem", fontStyle: "italic", lineHeight: "1.5" }}>💡 {q.tip}</p>}
      {q.type === "text" && (
        <input value={value || ""} onChange={e => onChange(e.target.value)} placeholder={q.placeholder}
          style={{ width: "100%", padding: "0.7rem 0.85rem", borderRadius: "8px", border: `1.5px solid ${value ? c.accent : c.border}`, fontFamily: "sans-serif", fontSize: "0.88rem", color: c.deep, outline: "none", boxSizing: "border-box", background: "#fff", transition: "border-color 0.15s" }} />
      )}
      {q.type === "textarea" && (
        <textarea value={value || ""} onChange={e => onChange(e.target.value)} placeholder={q.placeholder} rows={4}
          style={{ width: "100%", padding: "0.7rem 0.85rem", borderRadius: "8px", border: `1.5px solid ${value ? c.accent : c.border}`, fontFamily: "sans-serif", fontSize: "0.88rem", color: c.deep, outline: "none", boxSizing: "border-box", resize: "vertical", background: "#fff", lineHeight: "1.6", transition: "border-color 0.15s" }} />
      )}
      {q.type === "checkbox" && (
        <CheckboxGroup options={q.options} value={value || []} onChange={onChange} tip={q.tip} />
      )}
    </div>
  );
}

function generateSummary(answers) {
  const get = (id) => {
    const val = answers[id];
    if (Array.isArray(val)) return val.join(", ");
    return val || "[not answered]";
  };

  return `GRAND SLAM OFFER SUMMARY
========================

WHO I AM
Name: ${get("name")}
Background: ${get("background")} (${get("years")})
Why I opened up to something different: ${get("why_left")}
My ideal life: ${get("travel_life")}

MY AUDIENCE
Who I want to help: ${get("audience_who")}
Their biggest problem: ${get("audience_problem")}
The belief holding them back: ${get("audience_belief")}
What they actually want: ${get("audience_dream")}

MY OFFER
Core promise: ${get("core_promise")}
What I give them: ${get("what_you_give")}
My proof it works: ${get("your_story_proof")}
What makes my mentorship different: ${get("unique_angle")}
My commitment if they're struggling: ${get("guarantee")}

MY CONTENT FOUNDATION
The moment I went all in: ${get("origin_moment")}
Doubts and judgement I faced: ${get("doubts_faced")}
Where I'll show up: ${get("platforms")}
Content I'm most comfortable with: ${get("content_comfort")}
My brand in one sentence: ${get("one_sentence")}`;
}

